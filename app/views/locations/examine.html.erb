<section id="map"><img src="/maps" width=200 height=200></section>

<div><%= t('views.locations.examine.location_type', type: t("locations.#{location_type}")) %>

<% if can_create %>
  <%= form_for :project, url: projects_url, method: 'POST' do |form| %>
    <%= form.hidden_field :project_type_id, value: project_type_id %>
    <%= form.submit t('views.projects.create_location') %>
  <% end %>
<% else %>
  <div><%= t('views.locations.examine.cannot_create') %></div>
<% end %>