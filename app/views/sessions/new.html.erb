<div class="title-bar">
  <%= t 'views.sessions.new.title' %>
</div>

<div class="row" style="padding: 10px;">
  <div class="span6 offset3">
    <%= form_for(:session, url: sessions_url) do |f| %>

      <%= f.label :email %>
      <%= f.text_field :email %>

      <%= f.label :password %>
      <%= f.password_field :password %>

      <%= f.submit I18n.t 'views.layout.login', class: "btn btn-large btn-primary" %>
    <% end %>

    <p><%= t 'new_user' %>? <%= link_to I18n.t('views.layout.register'), register_url %></p>
  </div>
</div>
