<% provide(:js_name, 'characters') %>

<section id="current_user" data-id="<%= user.id %>">
  <div class="title-bar">
    <%= t('views.characters_list') %>
  </div>
  <% if characters.any? %>
    <table class="characters">
      <% characters.each do |character| %>
        <tr id="char_<%= character['id'] %>">
          <%= render 'characters/character', character: character %>
        </tr>
      <% end %>
    </table>
  <% else %>
    <%= t 'views.users.show.no_chars' %>
  <% end %>
  <% if user.can_create_character? %>
    <%= link_to I18n.t('views.users.show.create_char'), new_character_url %>
  <% else %>
    <%= t 'views.users.show.cannot_create_char' %>
  <% end %>
</section>