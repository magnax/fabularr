<%= t('views.location_objects.max_take') %> <%= @location_object.amount.to_i %> <%= td(@location_object.subject.unit) %> <%= td("resources.#{@resource.key}") %>

<%= form_for :inventory_object, url: inventory_objects_url, method: 'POST' do |form| %>
  <%= form.hidden_field :subject_id, value: @location_object.subject_id %>
  <%= form.hidden_field :subject_type, value: @location_object.subject_type %>
  <%= form.text_field :amount %>
  <%= form.submit t('views.location_objects.take') %>
<% end %>