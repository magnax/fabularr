<section id="character_information" style="float: left; width: 70%;">
  <div>
    <%= t 'views.events.index.name_title' %>: <%= link_to character.name_for(character), character_url(character.id) %>
    (<%= t "views.events.age", age: character.age %>)
  </div>
  <div>
    <%= t 'views.events.index.carrying' %>: <%= character.carrying_weight %>
    [<%= link_to t('views.events.index.inventory_page'), inventory_objects_url %>]
  </div>
  <div>
    <%= t 'views.events.index.location' %>: 
    <% if travel_info.present? %>
      <%= render 'travellers/travel_info', travel_info: travel_info, character: character %>
    <% else %>
      <%= link_to location_info[:toplevel_location_name], location_name_url(location_info[:toplevel_location_id]) %>
      <% if location_info[:sublocation_id] %>
        (<%= link_to location_info[:sublocation_name], location_name_url(location_info[:sublocation_id]) %>)
      <% end %>
      <%= location_info[:location_type] %>
    <% end %>
  </div>

  <% if character.location %>
    <div>
      <%= link_to t('views.events.index.build_menu'), recipes_url %>
    </div>
    <div>
      <% if character.location.town? %>
        <%= link_to t('views.events.index.build_road'), new_road_projects_url(location_id: character.location_id) %>
      <% end %>
    </div>
  <% end %>

  <% if character.can_start_travel? %>
    <div>
      <%= link_to t('views.events.index.travel'), new_traveller_url %>
    </div>
  <% end %>
</section>