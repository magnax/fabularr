<% if items.present? || machines.present? || resources.present? %>
  <% resources.each do |item| %>
    <div>
      <%= link_to fa_icon('upload'), location_object_take_url(item.id), title: t('views.location_objects.take') %>
      <%= item.amount.to_i %> <%= td(item.subject.unit) %> <%= td("resources.#{item.subject.key}") %>
    </div>
  <% end %>

  <% items.each do |item| %>
    <div>
      <%= link_to fa_icon('arrow-up'), location_object_take_item_url(item.id), title: t('views.location_objects.take') %>
      <%= t("items.damage.#{item.subject.damage_key}") %> <%= t("items.#{item.subject.item_type.key}") %>
    </div>
  <% end %>

  <% machines.each do |item| %>
    <div>
      <%= link_to fa_icon('hand-o-right'), '', title: t('views.machines.point') %>
      <%= link_to fa_icon('asterisk'), machine_recipes_url(id: item[:id]), title: t('views.machines.use') %>
      <%= t("machineries.#{item[:key]}") %>
      <% if item[:in_use] %>
        <i><%= t('machineries.in_use') %></i>
      <% end %>
    </div>
  <% end %>
<% else %>
  <%= t('items.nothing_here') %>
<% end %>