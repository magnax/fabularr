  <td>
		<%= link_to character[:name], character_set_url(character[:id]) %>
	</td>
	<td>
		<%= fa_icon(character[:male] ? 'mars' : 'venus', title: t("genders.#{character[:gender]}")) %>
	</td>
	<td>
		<% if character[:travel_info].present? %>
			<% if character[:travel_info][:end_location_name].present? %>
				<%= t(
					'views.users.show.travel_road_info_html', 
					start_location_name: character[:travel_info][:start_location_name],
					end_location_name: character[:travel_info][:end_location_name]
				) %>
			<% else %>
				<%= t(
					'views.users.show.travel_info_html', 
					location_name: character[:travel_info][:start_location_name],
					direction: character[:travel_info][:direction]
				) %>
			<% end %>
		<% else %>
			<%= character[:location_name] %>
		<% end %>
	</td>
	<td>
		<% if character[:location_type].present? %>
			<%= character[:location_type] %>
		<% end %>
	</td>
	<td>
		<% if character[:project_info] %>
			<a title="<%= character[:project_info][:name] %>"><%= fa_icon('cogs') %></a> (P <%= character[:project_info][:percent]%>%)</a>
		<% end %>
		<% if character[:travel_info] && character[:travel_info][:progress] %>
			(T <%= character[:travel_info][:progress] %>%)
		<% end %>
	</td>
