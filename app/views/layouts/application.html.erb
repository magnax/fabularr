<!DOCTYPE html>
<html>
<head>
  <title>Fabularr</title>
  <%= stylesheet_link_tag    "application", media: "all", "data-turbolinks-track" => true %>
  <%= javascript_include_tag "application", "data-turbolinks-track" => true %>
  <%= csrf_meta_tags %>
</head>
<body>
  <% if @current_character %>
	  <%= render 'layouts/character_header' %>
  <% else %>
	  <%= render 'layouts/header' %>
  <% end %>
	<% flash.each do |key, value| %>
    <% if key == 'errors' %>
      <div class="alert alert-<%= key %>"><%= value.split("\n").join('< /br>') %></div>
    <% else %>
      <div class="alert alert-<%= key %>"><%= value %></div>
    <% end %>
  <% end %>
	
  <%= yield %>

  <%= javascript_include_tag yield(:js_name), "data-turbolinks-track" => false %>
</body>
</html>
