<!DOCTYPE html>
<html>
<head>
  <title>Fabularr - admin panel</title>
  <%= stylesheet_link_tag    "admin", media: "all", "data-turbolinks-track" => true %>
  <%= javascript_include_tag "admin", "data-turbolinks-track" => true %>
  <%= csrf_meta_tags %>
</head>
<body>
  <section id="breadcrumbs">
    <%= render 'admin/breadcrumbs', items: breadcrumbs %>
  </section>

  <section id="menu">
    Characters
  </section>

  <section id="main">
    <% flash.each do |key, value| %>
      <% if key == 'errors' %>
        <div class="alert alert-<%= key %>"><%= value.split("\n").join('< /br>') %></div>
      <% else %>
        <div class="alert alert-<%= key %>"><%= value %></div>
      <% end %>
    <% end %>
    
    <%= yield %>
    
  </section>
	

</body>
</html>
